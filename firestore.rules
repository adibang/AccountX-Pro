rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() { return request.auth != null; }
    function isVerified() { 
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.email == 'adiblinggo@gmail.com'); 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isAdmin() { 
      return isSignedIn() && (
        (request.auth.token.email == 'adiblinggo@gmail.com') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      ); 
    }

    // Validation Blueprints
    function isValidAccount(data) {
      return data.keys().hasAll(['id', 'userId', 'code', 'name', 'type', 'initialBalance', 'currentBalance']) 
        && data.userId == request.auth.uid
        && data.code is string && data.code.size() <= 20
        && data.name is string && data.name.size() <= 100
        && data.type in ['ASET', 'KEWAJIBAN', 'EKUITAS', 'PENDAPATAN', 'BEBAN']
        && data.initialBalance is number
        && data.currentBalance is number;
    }

    function isValidJournalEntry(data) {
      return data.keys().hasAll(['userId', 'date', 'referenceCode', 'description', 'transactions', 'createdAt', 'createdBy'])
        && data.userId == request.auth.uid
        && data.referenceCode is string && data.referenceCode.size() <= 50
        && data.description is string && data.description.size() <= 500
        && data.createdBy == request.auth.uid;
    }

    function isValidContact(data) {
      return data.keys().hasAll(['userId', 'name']) 
        && data.userId == request.auth.uid
        && data.name is string && data.name.size() <= 200
        && (!data.keys().contains('email') || (data.email is string && data.email.size() <= 100))
        && (!data.keys().contains('phone') || (data.phone is string && data.phone.size() <= 50))
        && (!data.keys().contains('address') || (data.address is string && data.address.size() <= 500));
    }

    // Collection Rules
    match /accounts/{accountId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update: if isVerified() && isValidAccount(incoming());
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /journal_entries/{entryId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isVerified() && isValidJournalEntry(incoming());
      allow update: if (isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid)) && isValidJournalEntry(incoming());
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /customers/{customerId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update: if isVerified() && isValidContact(incoming());
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /suppliers/{supplierId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update: if isVerified() && isValidContact(incoming());
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId; 
      allow update: if isAdmin() || (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['displayName']));
    }
  }
}
